<mujoco model="panda ros2 scene">
  <!-- Include the official MuJoCo Menagerie Panda model -->
  <include file="panda.xml"/>

  <statistic center="0.3 0 0.4" extent="1"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
      rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <material name="table_mat" rgba="0.45 0.35 0.25 1" specular="0.2" shininess="0.1"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- Table -->
    <body name="table" pos="0.5 0 0.2">
      <geom name="table_top" type="box" size="0.3 0.4 0.02" pos="0 0 0.2" material="table_mat" mass="20"/>
      <geom name="table_leg1" type="cylinder" size="0.025 0.2" pos="0.25 0.35 0" material="table_mat"/>
      <geom name="table_leg2" type="cylinder" size="0.025 0.2" pos="-0.25 0.35 0" material="table_mat"/>
      <geom name="table_leg3" type="cylinder" size="0.025 0.2" pos="0.25 -0.35 0" material="table_mat"/>
      <geom name="table_leg4" type="cylinder" size="0.025 0.2" pos="-0.25 -0.35 0" material="table_mat"/>
    </body>
  </worldbody>

  <!-- ======================== -->
  <!-- Sensors for ROS2 bridge  -->
  <!-- ======================== -->
  <sensor>
    <!-- Joint position sensors -->
    <jointpos name="joint1_pos" joint="joint1"/>
    <jointpos name="joint2_pos" joint="joint2"/>
    <jointpos name="joint3_pos" joint="joint3"/>
    <jointpos name="joint4_pos" joint="joint4"/>
    <jointpos name="joint5_pos" joint="joint5"/>
    <jointpos name="joint6_pos" joint="joint6"/>
    <jointpos name="joint7_pos" joint="joint7"/>

    <!-- Joint velocity sensors -->
    <jointvel name="joint1_vel" joint="joint1"/>
    <jointvel name="joint2_vel" joint="joint2"/>
    <jointvel name="joint3_vel" joint="joint3"/>
    <jointvel name="joint4_vel" joint="joint4"/>
    <jointvel name="joint5_vel" joint="joint5"/>
    <jointvel name="joint6_vel" joint="joint6"/>
    <jointvel name="joint7_vel" joint="joint7"/>

    <!-- Actuator force sensors -->
    <actuatorfrc name="joint1_torque" actuator="actuator1"/>
    <actuatorfrc name="joint2_torque" actuator="actuator2"/>
    <actuatorfrc name="joint3_torque" actuator="actuator3"/>
    <actuatorfrc name="joint4_torque" actuator="actuator4"/>
    <actuatorfrc name="joint5_torque" actuator="actuator5"/>
    <actuatorfrc name="joint6_torque" actuator="actuator6"/>
    <actuatorfrc name="joint7_torque" actuator="actuator7"/>

    <!-- Finger position sensors -->
    <jointpos name="finger1_pos" joint="finger_joint1"/>
    <jointpos name="finger2_pos" joint="finger_joint2"/>

    <!-- End-effector sensors (hand body) -->
    <framepos name="ee_pos" objtype="body" objname="hand"/>
    <framequat name="ee_quat" objtype="body" objname="hand"/>
    <framelinvel name="ee_linvel" objtype="body" objname="hand"/>
    <frameangvel name="ee_angvel" objtype="body" objname="hand"/>
  </sensor>
</mujoco>
