<mujoco model="turtlebot_scene">
    <compiler angle="radian" autolimits="true"/>
    <option timestep="0.002" gravity="0 0 -9.81" integrator="implicitfast"/>

    <visual>
        <headlight ambient="0.35 0.35 0.35" diffuse="0.7 0.7 0.7"/>
    </visual>

    <default>
        <geom friction="1.2 0.05 0.01" condim="3"/>
    </default>

    <asset>
        <texture name="grid" type="2d" builtin="checker" rgb1="0.90 0.90 0.90" rgb2="0.82 0.82 0.82" width="256" height="256"/>
        <material name="mat_floor" texture="grid" texrepeat="8 8"/>
        <material name="mat_wall" rgba="0.45 0.48 0.52 1"/>
        <material name="mat_obs" rgba="0.66 0.30 0.24 1"/>
        <material name="mat_bot" rgba="0.13 0.42 0.64 1"/>
        <material name="mat_wheel" rgba="0.08 0.08 0.08 1"/>
    </asset>

    <worldbody>
        <light name="sun" pos="0 0 3" dir="0 0 -1" diffuse="0.95 0.95 0.95" castshadow="false"/>

        <geom name="floor" type="plane" pos="0 0 0" size="5 5 0.1" material="mat_floor"/>

        <!-- Thin boundary walls forming a 2m x 2m environment. -->
        <geom name="wall_north" type="box" pos="0 2 0.2" size="2 0.04 0.2" material="mat_wall"/>
        <geom name="wall_south" type="box" pos="0 -2 0.2" size="2 0.04 0.2" material="mat_wall"/>
        <geom name="wall_east" type="box" pos="2 0 0.2" size="0.04 2 0.2" material="mat_wall"/>
        <geom name="wall_west" type="box" pos="-2 0 0.2" size="0.04 2 0.2" material="mat_wall"/>

        <!-- Static obstacles -->
        <geom name="obs_a" type="box" pos="0.55 0.40 0.10" size="0.18 0.12 0.1" material="mat_obs"/>
        <geom name="obs_b" type="box" pos="-0.50 0.35 0.10" size="0.14 0.22 0.1" material="mat_obs"/>
        <geom name="obs_c" type="box" pos="-0.35 -0.45 0.10" size="0.25 0.10 0.1" material="mat_obs"/>
        <geom name="obs_d" type="cylinder" pos="0.35 -0.30 0.10" size="0.11 0.1" material="mat_obs"/>
        <geom name="obs_e" type="box" pos="1.65 1.05 0.10" size="0.18 0.08 0.1" material="mat_obs"/>
        <geom name="obs_f" type="cylinder" pos="-1.15 1.35 0.10" size="0.10 0.1" material="mat_obs"/>
        <geom name="obs_g" type="box" pos="0.95 -1.30 0.10" size="0.22 0.09 0.1" material="mat_obs"/>
        <geom name="obs_h" type="cylinder" pos="-1.70 -1.10 0.10" size="0.08 0.1" material="mat_obs"/>
        <geom name="obs_i" type="box" pos="1.55 -0.10 0.10" size="0.08 0.28 0.1" material="mat_obs"/>

        <body name="turtlebot" pos="-1 -1 0.036">
            <freejoint name="tb_free"/>
            <inertial pos="0 0 0" mass="2.2" diaginertia="0.02 0.02 0.03"/>

            <!-- Keep one clean collision chassis + one visual shell for easier debugging. -->
            <geom name="tb_chassis_col" type="cylinder" size="0.078 0.020" material="mat_bot" contype="0" conaffinity="0"/>
            <geom name="tb_chassis_vis" type="cylinder" size="0.095 0.014" pos="0 0 0.024" material="mat_bot" contype="0" conaffinity="0"/>

            <!-- Add a front and rear caster so the robot base doesn't tip over. -->
            <geom name="tb_caster_front" type="sphere" pos="0.075 0 -0.025" size="0.008" mass="0.02" friction="0.02 0.001 0.0001" condim="3"/>
            <geom name="tb_caster_back" type="sphere" pos="-0.075 0 -0.025" size="0.008" mass="0.02" friction="0.02 0.001 0.0001" condim="3"/>

            <body name="tb_left_wheel" pos="0 0.09 0">
                <joint name="tb_left_wheel_joint" type="hinge" axis="0 1 0" damping="0.05" frictionloss="0.01"/>
                <geom name="tb_left_wheel_geom" type="cylinder" size="0.033 0.016" euler="1.57079632679 0 0" material="mat_wheel" friction="1.8 0.02 0.001" condim="6"/>
            </body>

            <body name="tb_right_wheel" pos="0 -0.09 0">
                <joint name="tb_right_wheel_joint" type="hinge" axis="0 1 0" damping="0.05" frictionloss="0.01"/>
                <geom name="tb_right_wheel_geom" type="cylinder" size="0.033 0.016" euler="1.57079632679 0 0" material="mat_wheel" friction="1.8 0.02 0.001" condim="6"/>
            </body>

